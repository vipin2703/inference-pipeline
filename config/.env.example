# Copy:  cp .env.example .env   (ya Windows pe rename)
# Used by: docker-compose.yml (vLLM + Langfuse stack)

# ---- vLLM image / model ----
VLLM_IMAGE=vllm/vllm-openai:latest
# Windows path: forward slash use karo
MODEL_HOST_PATH=C:/path/to/your/model
MODEL_CONTAINER_PATH=/models
MODEL_NAME_PATH=
SERVED_MODEL_NAME=gemma4

QUANTIZATION=
KV_CACHE_DTYPE=auto
MAX_NUM_BATCHED_TOKENS=4096
MAX_MODEL_LEN=8192
TENSOR_PARALLEL_SIZE=1
GPU_MEMORY_UTILIZATION=0.70
HOST=0.0.0.0
PORT=8000

# ---- Langfuse app ----
DATABASE_URL=postgresql://postgresuser:CHANGE_ME@postgres:5432/postgresdb
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CHANGE_ME_openssl_rand_base64_32
SALT=CHANGE_ME_openssl_rand_base64_16
ENCRYPTION_KEY=CHANGE_ME_64_hex_chars_openssl_rand_hex_32
TELEMETRY_ENABLED=true
LANGFUSE_ENABLE_EXPERIMENTAL_FEATURES=false

# ---- Langfuse init user (first login) ----
LANGFUSE_INIT_ORG_ID=my-org
LANGFUSE_INIT_ORG_NAME=My Org
LANGFUSE_INIT_PROJECT_ID=my-project
LANGFUSE_INIT_PROJECT_NAME=my-project
LANGFUSE_INIT_USER_EMAIL=you@example.com
LANGFUSE_INIT_USER_NAME=admin
LANGFUSE_INIT_USER_PASSWORD=CHANGE_ME
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
LANGFUSE_INIT_PROJECT_SECRET_KEY=

# ---- ClickHouse ----
CLICKHOUSE_DB=langfuse
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=CHANGE_ME
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_MIGRATION_URL=clickhouse://clickhouse:9000
CLICKHOUSE_CLUSTER_ENABLED=false

# ---- MinIO (S3) ----
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=CHANGE_ME
LANGFUSE_S3_EVENT_UPLOAD_BUCKET=langfuse
LANGFUSE_S3_EVENT_UPLOAD_REGION=auto
LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=minio
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=CHANGE_ME
LANGFUSE_S3_EVENT_UPLOAD_ENDPOINT=http://minio:9000
LANGFUSE_S3_EVENT_UPLOAD_FORCE_PATH_STYLE=true
LANGFUSE_S3_EVENT_UPLOAD_PREFIX=events/
LANGFUSE_S3_MEDIA_UPLOAD_BUCKET=langfuse
LANGFUSE_S3_MEDIA_UPLOAD_REGION=auto
LANGFUSE_S3_MEDIA_UPLOAD_ACCESS_KEY_ID=minio
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=CHANGE_ME
LANGFUSE_S3_MEDIA_UPLOAD_ENDPOINT=http://localhost:9090
LANGFUSE_S3_MEDIA_UPLOAD_FORCE_PATH_STYLE=true
LANGFUSE_S3_MEDIA_UPLOAD_PREFIX=media/

# ---- Redis / Postgres ----
REDIS_HOST=redis
REDIS_AUTH=CHANGE_ME
POSTGRES_USER=postgresuser
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=postgresdb
