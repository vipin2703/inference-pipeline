# Copy:  cp .env.example .env   (ya Windows pe rename)
# Used by: backend container (client.py) — docker-compose env_file

# ---- vLLM (Docker network: service name, not localhost) ----
BASE_URL=http://vllm-server:8000/v1
API_KEY=not-needed
MODEL_NAME=gemma4

# ---- Langfuse tracing (backend → langfuse-web) ----
# LANGFUSE_HOST: container-to-container → service name use karo
LANGFUSE_HOST=http://langfuse-web:3000
# Keys: Langfuse UI → Project → Settings → API Keys
# (ya config/.env ke LANGFUSE_INIT_PROJECT_* se)
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
